{
  "actions": [
    {
      "id": "check_maya_version",
      "action": "check maya version",
      "desc": "检测Maya版本",
      "action_module": "check_maya_version.py",
      "params": {
        "maya_version":
          {"type":"select",
          "select_list":["2018","2019","2020","2022","2023"],
          "description": "Maya版本",
          "default": "2020",
          "allow_skin": false}
      }
    },
    {
      "id": "set_frame_range",
      "action": "set frame range",
      "desc": "设置帧范围",
      "py": "set_frame_range",
      "params": {
        "起始帧": "1",
        "结束帧": "100"
      }
    },
    {
      "id": "import_reference",
      "action": "import reference",
      "desc": "导入参考文件",
      "py": "import_reference",
      "params": {
        "文件路径": "{file_path}",
        "命名空间": "REF"
      }
    },
    {
      "id": "create_camera",
      "action": "create camera",
      "desc": "创建摄像机",
      "py": "create_camera",
      "params": {
        "摄像机名称": "CAM_main",
        "焦距": "35.0"
      }
    },
    {
      "id": "export_fbx",
      "action": "export fbx",
      "desc": "导出FBX文件",
      "py": "export_fbx",
      "params": {
        "输出路径": "{output_path}",
        "选择模式": "selected"
      }
    },
    {
      "id": "bake_animation",
      "action": "bake animation",
      "desc": "烘焙动画",
      "py": "bake_animation",
      "params": {
        "开始帧": "1",
        "结束帧": "100",
        "步长": "1"
      }
    },
    {
      "id": "clean_scene",
      "action": "clean scene",
      "desc": "清理场景",
      "py": "clean_scene",
      "params": {
        "删除未使用节点": "true",
        "优化场景": "true"
      }
    },
    {
      "id": "create_group",
      "action": "create group",
      "desc": "创建组",
      "py": "create_group",
      "params": {
        "组名称": "NEW_GROUP"
      }
    },
    {
      "id": "newfile",
      "action": "new maya file",
      "desc": "新建Maya文件",
      "py": "new_maya_file",
      "params": {
        "文件保存路径": "D:/Projects/temp.ma",
        "初始设置": "default"
      }
    },
    {
      "id": "make_group",
      "action": "make group",
      "desc": "创建组",
      "py": "make_group",
      "params": {
        "组名称": "animation_group",
        "组类型": "animation"
      }
    },
    {
      "id": "reference_maya_file",
      "action": "reference maya file",
      "desc": "引用Maya文件",
      "py": "reference_maya_file",
      "params": {
        "被引用文件路径": "D:/Projects/asset.ma",
        "命名空间": "REF"
      }
    },
    {
      "id": "reference_abc_file",
      "action": "reference abc file",
      "desc": "引用Alembic文件",
      "py": "reference_abc_file",
      "params": {
        "ABC文件路径": "D:/Projects/cache.abc",
        "导入模式": "import"
      }
    },
    {
      "id": "setfps",
      "action": "set frame rate",
      "desc": "设置帧速率",
      "py": "set_frame_rate",
      "params": {
        "帧速率": "24"
      }
    },
    {
      "id": "make_camera",
      "action": "make camera",
      "desc": "生成摄像机",
      "py": "make_camera",
      "params": {
        "摄像机类型": "perspective",
        "焦距": "35"
      }
    },
    {
      "id": "save_file",
      "action": "save file",
      "desc": "保存文件",
      "py": "save_file",
      "params": {
        "保存路径": "D:/Projects/output.ma",
        "覆盖选项": "false"
      }
    }
  ]
}
